# ============================================
# Phase 3: 无括号调用交互深化测试
# ============================

# =====================
# FN-25: 无括号调用与运算符交互
# =====================
def add a, b
    return a + b

# add 1 + 2 3 → 应解析为 add(1+2, 3) = add(3, 3) = 6
# 因为 + 优先级高于无括号调用参数分隔
result = add 1 + 2, 3
print result

# =====================
# FN-26: 链式调用
# =====================
def double x
    return x * 2

def inc x
    return x + 1

# 链式: inc double 5 → inc(double(5)) = inc(10) = 11
print inc double 5

# =====================
# 补充: 无括号调用与字符串
# =====================
def greet name
    return "hello " + name

print greet "world"

# =====================
# 补充: 显式括号调用与表达式
# =====================
print add(10, 20)

# =====================
# 补充: 函数调用作为表达式的一部分
# =====================
x = add(3, 4) * 2
print x

print "--- p3_call_interactions done ---"
