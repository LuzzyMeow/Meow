# ============================================
# Phase 3: 匿名函数深化测试
# ============================================

# =====================
# FN-14: 匿名函数立即调用
# =====================
result = (fn x -- x * 2) 5
print result

# =====================
# FN-15: 匿名函数作为参数
# =====================
def apply f, x
    return f x

inc = fn x -- x + 10
print apply inc, 5

# =====================
# FN-16: 多参数匿名函数
# =====================
adder = fn a, b -- a + b
print adder(3, 7)

# =====================
# 补充: 匿名函数在列表中使用
# =====================
f1 = fn x -- x + 1
f2 = fn x -- x * 2
print f1 10
print f2 10

# =====================
# 补充: 匿名函数捕获变量
# =====================
base = 100
add_base = fn x -- x + base
print add_base 5

print "--- p3_lambda done ---"
