# ============================================
# Meow 语言控制流测试 (Stage 2)
# ============================================

# =====================
# 1. if 语句测试
# =====================

# 1.1 基本 if
x = 10
if x > 5
    print "x > 5"

# 1.2 if-else
y = 3
if y > 5
    print "y > 5"
else
    print "y <= 5"

# 1.3 if-elif-else 链
score = 85
if score >= 90
    print "A"
elif score >= 80
    print "B"
elif score >= 70
    print "C"
else
    print "D"

# 1.4 嵌套 if
a = 10
b = 20
if a > 5
    if b > 15
        print "a > 5 and b > 15"

# 1.5 逻辑条件作if条件
if true
    print "true branch"

if false
    print "false branch (should NOT print)"
else
    print "false else branch"

# 1.6 null 作为条件（falsy）
val = null
if val
    print "null is truthy (should NOT print)"
else
    print "null is falsy"

# 1.7 0 作为条件（falsy）
if 0
    print "0 is truthy (should NOT print)"
else
    print "0 is falsy"

# 1.8 非零数字作为条件（truthy）
if 42
    print "42 is truthy"

print "--- if tests done ---"

# =====================
# 2. for 循环测试
# =====================

# 2.1 基本 for + range
print "for 1-5:"
for i in range 5
    print i

# 2.2 for + range(start, end)
print "for 3-7:"
for i in range 3,7
    print i

# 2.3 for 迭代列表
items = [10, 20, 30]
print "list items:"
for item in items
    print item

# 2.4 for 累加
sum_val = 0
for i in range 10
    sum_val = sum_val + i
print sum_val

print "--- for tests done ---"

# =====================
# 3. while 循环测试
# =====================

# 3.1 基本 while
count = 3
while count > 0
    print count
    count = count - 1

# 3.2 while 累乘
n = 1
result = 1
while n <= 5
    result = result * n
    n = n + 1
print result

print "--- while tests done ---"

# =====================
# 4. break/continue 测试
# =====================

# 4.1 for + break
print "for break:"
for i in range 10
    if i > 5
        break
    print i

# 4.2 for + continue
print "for continue (skip 5):"
for i in range 10
    if i == 5
        continue
    print i

# 4.3 while + break
print "while break:"
j = 1
while true
    if j > 3
        break
    print j
    j = j + 1

# 4.4 while + continue
print "while continue:"
k = 0
while k < 6
    k = k + 1
    if k == 3
        continue
    print k

print "--- break//continue tests done ---"

# =====================
# 5. 综合测试
# =====================

# 5.1 打印1-100中3的倍数
print "multiples of 3 (1-15):"
for i in range 15
    if i % 3 == 0
        print i

# 5.2 判断质数
num = 17
is_prime = true
if num < 2
    is_prime = false
else
    d = 2
    while d < num
        if num % d == 0
            is_prime = false
            break
        d = d + 1
if is_prime
    print num ++ " is prime"
else
    print num ++ " is not prime"

# 5.3 嵌套循环
print "multiplication table (2x3):"
for i in range 2
    for j in range 3
        print i * j

print "--- all control flow tests done ---"
