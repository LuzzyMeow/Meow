# Phase 1: 变量作用域测试

# === if 块级作用域 ===
x = "outer"
if true
    y = "inner"
    print y
# y 在 if 块外不应可访问
try
    print y
except e
    print "y not accessible outside if block"

# === for 块级作用域 ===
for i in range 1, 3
    loop_var = i
    print loop_var
# loop_var 在 for 块外不应可访问
try
    print loop_var
except e
    print "loop_var not accessible outside for block"

# === 未定义变量访问 ===
try
    print undefined_var
except e
    print "undefined variable caught"
