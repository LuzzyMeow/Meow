# 阶段 1：变量与表达式测试

# === 1.1 变量赋值 ===
x = 10
print x

name = "Alice"
print name

# 连续赋值
a = b = 5
print a
print b

# === 1.2 算术运算 ===
print 10 + 20
print 20 - 5
print 6 * 7
print 20 / 3
print 20 // 3
print 20 % 3
print 2 ** 10

# 复合表达式
print 1 + 2 * 3
print (1 + 2) * 3

# 负数
print -5
print -10 + 3

# 浮点数
print 3.14 * 2
print 10 / 3

# === 1.3 字符串插值 ===
name = "世界"
print "你好, /name"

x = 10
y = 20
print "x + y = /(x + y)"
print "/(x) + /(y) = /(x + y)"

# === 1.4 比较运算 ===
print 10 == 10
print 10 != 5
print 10 > 5
print 10 < 5
print 10 >= 10
print 10 <= 9

# === 1.5 逻辑运算 ===
print true and false
print true or false
print not true
print not false

# === 1.6 增强赋值 ===
n = 10
n += 5
print n

n -= 3
print n

n *= 2
print n

n /= 4
print n

# === 1.7 null 和布尔 ===
print null
print true
print false
