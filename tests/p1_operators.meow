# Phase 1: 运算符测试

# === and 短路求值 ===
x = 0
result = false and x == 1
print result

# === or 短路求值 ===
result = true or x == 1
print result

# === in 成员运算 ===
print 3 in [1, 2, 3]
print 4 in [1, 2, 3]

# === not in 成员运算 ===
print 4 not in [1, 2, 3]
print 3 not in [1, 2, 3]

# === 列表并集 ++ ===
a = [1, 2, 3]
b = [2, 3, 4]
print a ++ b

# === 列表交集 && ===
print a && b

# === 列表差集 -- ===
print a -- b

# === 列表对称差 --/ ===
print a --/ b

# === 运算符优先级 ===
print 2 + 3 * 4
print 2 ** 3 * 2
print 1 + 2 ** 3

# === 负数取余 ===
neg7 = 0 - 7
neg3 = 0 - 3
print neg7 % 3
print 7 % neg3

# === 除零处理 ===
try
    x = 10 / 0
    print x
except e
    print "division by zero caught"
